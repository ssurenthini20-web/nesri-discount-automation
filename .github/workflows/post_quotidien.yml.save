




































































name: Post Instagram Quotidien

on:
  schedule:
    - cron: '0 7 * * *'  # Chaque jour a 7h du matin
  workflow_dispatch:  # Pour tester manuellement

jobs:
  envoyer-post:
    runs-on: ubuntu-latest
    steps:
      - name: Recuperer le code
        uses: actions/checkout@v3

      - name: Installer Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.11'

      - name: Installer les librairies
        run: |
          pip install pandas groq python-dotenv pillow requests

      - name: Lancer le programme
        env:
          GROQ_API_KEY: ${{ secrets.GROQ_API_KEY }}
          EMAIL_EXPEDITEUR: ${{ secrets.EMAIL_EXPEDITEUR }}
          EMAIL_MOT_DE_PASSE: ${{ secrets.EMAIL_MOT_DE_PASSE }}
          EMAIL_DESTINATAIRE: ${{ secrets.EMAIL_DESTINATAIRE }}
        run: |
          cd 02_Notebooks_Python
          jupyter nbconvert --to script Mission3_Automatisation.ipynb
          python Mission3_Automatisation.py
